#!/usr/bin/env bash
# ansil16 -- apply a 16-color ANSI palette.
#
# Subcommands:
#   set NAME [--auto|-k|--kitty|-o|--osc] [-a|--all] [-s|--kitty-socket]
#                      apply palette. Default --auto prefers kitty IPC if
#                      reachable, falls back to OSC; -a/--all is OSC-only and
#                      broadcasts to every tty; -s/--kitty-socket forces kitty
#                      backend via a discovered listening socket (for external
#                      use: Raycast, skhd, launchd — see
#                      notes/external-invocation.md).
#   reset [--all]      reset to terminal defaults: bg/fg/cursor (]111 ]110 ]112)
#                      AND all 16 ANSI slots (]104). Emits to current tty by
#                      default; --all broadcasts to every tty and also clears
#                      the persisted-palette state file.
#   list               list available palettes
#   current            print active palette name (from state file)
#   path NAME          print resolved path of a palette

set -euo pipefail

_self=$0
while [[ -L $_self ]]; do
    _link=$(readlink "$_self")
    case $_link in
        /*) _self=$_link ;;
        *)  _self=$(cd "$(dirname "$_self")" && pwd -P)/$_link ;;
    esac
done
SELF_DIR=$(cd "$(dirname "$_self")" && pwd -P)
# shellcheck source=../lib/common.sh
. "$SELF_DIR/../lib/common.sh"

usage() {
    cat >&2 <<'EOF'
Usage:
  ansil16 set NAME [--auto|-k|--kitty|-o|--osc] [-a|--all] [-s|--kitty-socket]
                             apply palette. --auto (default) prefers kitty
                             IPC if reachable, falls back to OSC.
                             -a/--all (OSC only) = broadcast to every tty.
                             -s/--kitty-socket = use a discovered kitty
                             socket (for external callers; implies --kitty).
  ansil16 reset [--all]      emit reset OSC to current tty (or every tty)
  ansil16 list               list available palettes
  ansil16 current            print active palette name
  ansil16 path NAME          print resolved path of palette
EOF
    exit 1
}

state_dir=$(ansil16_state_dir)
current_file=$state_dir/current

[[ $# -ge 1 ]] || usage
cmd=$1; shift

case $cmd in
    set)
        [[ $# -ge 1 ]] || usage
        name=$1; shift
        mode=auto
        broadcast=
        use_socket=
        while [[ $# -gt 0 ]]; do
            case $1 in
                --auto)                mode=auto;     shift ;;
                -k|--kitty)            mode=kitty;    shift ;;
                -o|--osc)              mode=osc;      shift ;;
                -a|--all)              broadcast=1;   shift ;;
                -s|--kitty-socket)     use_socket=1;  shift ;;
                *) echo "ansil16: unknown arg: $1" >&2; usage ;;
            esac
        done
        # --kitty-socket implies the kitty backend: external callers (Raycast,
        # skhd, launchd, cron) have no controlling tty, so the OSC path can't
        # work. Reject combinations that contradict that.
        if [[ -n $use_socket ]]; then
            case $mode in
                osc) echo "ansil16: --kitty-socket is incompatible with --osc" >&2; exit 1 ;;
                *)   mode=kitty ;;
            esac
            [[ -z $broadcast ]] || { echo "ansil16: --kitty-socket is incompatible with --all" >&2; exit 1; }
        fi
        palette=$(ansil16_find_palette "$name") || {
            echo "ansil16: no palette named '$name'" >&2
            avail=$(ansil16_list_palettes | tr '\n' ' ')
            [[ -n $avail ]] && echo "  available: $avail" >&2
            exit 1
        }
        # Resolve effective backend.
        backend=
        case $mode in
            kitty) backend=kitty ;;
            osc)   backend=osc ;;
            auto)
                if ansil16_kitty_reachable; then backend=kitty
                else backend=osc
                fi ;;
        esac
        case $backend in
            kitty)
                if [[ -n $use_socket ]]; then
                    "$SELF_DIR/ansil16-kitty" "$palette" --kitty-socket
                else
                    "$SELF_DIR/ansil16-kitty" "$palette"
                fi ;;
            osc)
                if [[ -n $broadcast ]]; then
                    "$SELF_DIR/ansil16-emit" "$palette" --all
                else
                    "$SELF_DIR/ansil16-emit" "$palette"
                fi ;;
        esac
        mkdir -p "$state_dir"
        printf '%s\n' "$name" > "$current_file"
        ;;
    reset)
        reset_all=
        while [[ $# -gt 0 ]]; do
            case $1 in
                --all) reset_all=1; shift ;;
                *) echo "ansil16: unknown arg: $1" >&2; usage ;;
            esac
        done
        if [[ -n $reset_all ]]; then
            seq=$(ansil16_render_reset_osc)
            ansil16_find_ttys | while IFS= read -r tty; do
                [[ -w $tty ]] && printf '%s' "$seq" > "$tty" 2>/dev/null || true
            done
            # --all means "globally back to defaults" — drop the persisted
            # choice so `ansil16 current` reports (none) honestly. The narrow
            # form (this tty only) keeps state intact since other ttys are
            # still showing the previous palette.
            rm -f "$current_file"
        else
            ansil16_render_reset_osc
        fi
        ;;
    list)
        ansil16_list_palettes
        ;;
    current)
        if [[ -f $current_file ]]; then
            cat "$current_file"
        else
            echo "(none)" >&2
            exit 1
        fi
        ;;
    path)
        [[ $# -ge 1 ]] || usage
        ansil16_find_palette "$1" || {
            echo "ansil16: no palette named '$1'" >&2
            exit 1
        }
        ;;
    -h|--help) usage ;;
    *) echo "ansil16: unknown subcommand: $cmd" >&2; usage ;;
esac
